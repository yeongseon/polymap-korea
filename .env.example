# PolyMap Korea development environment variables

# App
POLYMAP_APP_VERSION=0.1.0
POLYMAP_DEBUG=false
POLYMAP_CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL
POSTGRES_PASSWORD=changeme-postgres-password
POLYMAP_DATABASE_URL=postgresql+asyncpg://polymap:changeme-postgres-password@localhost:5432/polymap

# OpenSearch
POLYMAP_OPENSEARCH_URL=http://localhost:9200

# MinIO / S3
MINIO_ROOT_USER=polymap
MINIO_ROOT_PASSWORD=changeme-minio-password
POLYMAP_S3_ENDPOINT=http://localhost:9000
POLYMAP_S3_ACCESS_KEY=polymap
POLYMAP_S3_SECRET_KEY=changeme-minio-password
POLYMAP_S3_BUCKET_RAW=polymap-raw

# External APIs
POLYMAP_ADMIN_API_KEY=changeme-admin-api-key
POLYMAP_JUSO_API_KEY=changeme-juso-api-key
POLYMAP_NEC_API_KEY=changeme-nec-api-key
POLYMAP_ASSEMBLY_API_KEY=changeme-assembly-api-key

# Prefect
POLYMAP_PREFECT_API_URL=http://localhost:4200/api
