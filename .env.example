# PolyMap Korea development environment variables

# App
POLYMAP_APP_VERSION=0.1.0
POLYMAP_DEBUG=false

# PostgreSQL
POSTGRES_PASSWORD=polymap_dev
POLYMAP_DATABASE_URL=postgresql+asyncpg://polymap:polymap_dev@localhost:5432/polymap

# Redis
POLYMAP_REDIS_URL=redis://localhost:6379/0

# OpenSearch
POLYMAP_OPENSEARCH_URL=http://localhost:9200

# MinIO / S3
MINIO_ROOT_USER=polymap
MINIO_ROOT_PASSWORD=polymap_dev
POLYMAP_S3_ENDPOINT=http://localhost:9000
POLYMAP_S3_ACCESS_KEY=polymap
POLYMAP_S3_SECRET_KEY=polymap_dev
POLYMAP_S3_BUCKET_RAW=polymap-raw

# External APIs
POLYMAP_NEC_API_KEY=
POLYMAP_ASSEMBLY_API_KEY=

# Prefect
POLYMAP_PREFECT_API_URL=http://localhost:4200/api
